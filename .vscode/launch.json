{
    "version": "0.2.0",
    "configurations":[
        {
            "name": "C/C++: gcc.exe 调试活动文件",
            "type": "cppdbg",
            "request": "launch",
            "program": "${fileDirname}\\${fileBasenameNoExtension}.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment":[],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "D:\\mingw64\\mingw64\\bin\\gdb.exe",  // 根据你的tasks.json已修正为正确的D盘路径
            "setupCommands":[
                {
                    "description": "为 gdb 启用整齐打印",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "C/C++: gcc.exe build active file" // 已修正，与tasks.json的label完全一致
        }
    ]
} 